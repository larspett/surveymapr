    stringr,
    sf,
    magick,
    widgetframe,
    htmlwidgets,
    webshot2,
    purrr,
    tibble,
    tidyr,
    lubridate,
    leaflet,
    leaflet.providers,
    RColorBrewer
Depends: 
    R (>= 4.10)
RoxygenNote: 7.3.2
